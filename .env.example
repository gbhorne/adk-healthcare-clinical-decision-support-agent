# HC-CDSS Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to source control — it contains project-specific
# resource paths and should be in .gitignore.

# ── Required ──────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-new-project-id-here
GCP_LOCATION=us-central1

# ── Cloud Healthcare API (FHIR) ───────────────────────────────────────────────
FHIR_DATASET_ID=cds-dataset
FHIR_STORE_ID=cds-fhir-store

# ── Vertex AI ─────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
VERTEX_AI_SEARCH_ENGINE_ID=cds-clinical-protocols

# ── Cloud DLP (optional — inline config used when not set) ────────────────────
# Set these after creating DLP templates in your new project.
# Format: projects/YOUR-PROJECT/locations/us-central1/inspectTemplates/cds-phi-inspect
DLP_INSPECT_TEMPLATE=
DLP_DEIDENTIFY_TEMPLATE=

# ── Cloud KMS (optional — set after creating KMS key ring) ───────────────────
# Format: projects/YOUR-PROJECT/locations/us-central1/keyRings/cds-keyring/cryptoKeys/dlp-deidentify-key
KMS_KEY_NAME=

# ── Cloud Storage ─────────────────────────────────────────────────────────────
# Format: your-new-project-id-cdss-data  (no gs:// prefix)
GCS_BUCKET=your-new-project-id-cdss-data

# ── Pub/Sub Topics (defaults are fine) ────────────────────────────────────────
TOPIC_PATIENT_CONTEXT_READY=patient-context-ready
TOPIC_DIAGNOSIS_READY=diagnosis-ready
TOPIC_PROTOCOLS_READY=protocols-ready
TOPIC_DRUG_INTERACTIONS_READY=drug-interactions-ready
TOPIC_AUDIT_EVENTS=audit-events

# ── Pub/Sub Subscriptions (defaults are fine) ─────────────────────────────────
SUB_DIAGNOSIS_AGENT=diagnosis-agent-sub
SUB_PROTOCOL_AGENT=protocol-agent-sub
SUB_DRUG_INTERACTION_AGENT=drug-interaction-agent-sub
SUB_DRUG_INTERACTION_PATIENT_CONTEXT=drug-interaction-patient-context-sub
SUB_ORCHESTRATOR_AGENT=orchestrator-agent-sub
SUB_ORCHESTRATOR_DIAGNOSIS=orchestrator-diagnosis-sub
SUB_ORCHESTRATOR_PROTOCOLS=orchestrator-protocols-sub
SUB_AUDIT_AGENT=audit-agent-sub

# ── Firestore ─────────────────────────────────────────────────────────────────
FIRESTORE_COLLECTION=cds_sessions

# ── BigQuery ──────────────────────────────────────────────────────────────────
BQ_DATASET=cds_audit
BQ_AUDIT_TABLE=audit_log
BQ_SESSIONS_TABLE=sessions
